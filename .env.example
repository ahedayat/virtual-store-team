# PostgreSQL (used by postgres service and future backend DATABASE_URL wiring)
POSTGRES_DB=virtual_store
POSTGRES_USER=virtual_store
POSTGRES_PASSWORD=change-me-in-production

# Database connection string (placeholder; Django Postgres wiring is a later step)
DATABASE_URL=postgres://virtual_store:change-me-in-production@postgres:5432/virtual_store

# Redis and Celery (Step 5.1)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT service-to-service auth (Phase 2.2+)
JWT_SERVICE_SECRET=change-me-in-local-dev
JWT_SERVICE_AUDIENCE=ai-services
JWT_SERVICE_ALGORITHM=HS256
JWT_SERVICE_TOKEN_LIFETIME_MINUTES=30

# AI / language (placeholders; no real LLM calls in Step 0.4)
AI_OUTPUT_LANGUAGE=en
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-placeholder
ANTHROPIC_API_KEY=sk-ant-placeholder

# Internal service URLs (Docker DNS names)
DJANGO_INTERNAL_BASE_URL=http://backend:8000
COORDINATOR_AGENT_URL=http://coordinator-agent:8100
SALES_AGENT_URL=http://sales-agent:8101
CONTENT_AGENT_URL=http://content-agent:8102
SUPPORT_AGENT_URL=http://support-agent:8103

# Frontend (browser-facing; use localhost when ports are exposed in development)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
